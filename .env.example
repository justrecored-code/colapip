# ============================================================================
# VibePractice - Environment Variables
# ============================================================================
# Copy this file to .env and fill in values as needed.
# All variables have sensible defaults for local development.
# ============================================================================

# --- ComfyUI (recipe-engine 插件) ---
# 默认: http://127.0.0.1:8188
# COMFYUI_URL=http://127.0.0.1:8188

# --- WeChat Download API (wechat-scrape) ---
# 默认: http://127.0.0.1:14000
# WECHAT_API_URL=http://127.0.0.1:14000
